# Server
PORT=5000
NODE_ENV=development

# Hugging Face - Get your token at https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxx

# Murf AI - Get your API key at https://murf.ai/resources/api
MURF_API_KEY=your_murf_api_key_here

# Firebase - Download service account JSON from Firebase Console
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
FIREBASE_SERVICE_ACCOUNT_PATH=./config/serviceAccountKey.json

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
